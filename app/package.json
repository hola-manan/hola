    "react-router-dom": "^7.18.1",
    "tailwindcss": "^4.3.2",
    "vite-plugin-pwa": "^1.3.0"
  },
  "devDependencies": {
    "@types/node": "^24.13.3",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.3",
    "firebase-tools": "^15.23.0",
    "oxlint": "^1.71.0",
